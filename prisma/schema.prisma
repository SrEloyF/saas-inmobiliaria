generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Equipo {
  Interno
  Franquiciado
  Externo
}

enum EstadoCivil {
  Soltero
  Casado
  Divorciado
  Viudo
}

enum MedioPago {
  Transferencia
  Deposito
  Cheque_de_gerencia
}

enum Modalidad {
  Financiado
  Al_contado
}

enum TipoComprobante {
  Boleta
  Factura
}

enum Moneda {
  Soles
  Dolares
}

model Asesor {
  id               Int      @id @default(autoincrement())
  nombre_completo  String
  created_at       DateTime @default(now()) @db.Timestamp(3)

  ventas           Venta[]

  @@map("asesores")
}

model Cliente {
  id                Int         @id @default(autoincrement())
  nombre_completo   String
  celular           String
  dni_ruc           String
  direccion         String
  distrito          String
  provincia         String
  departamento      String
  ocupacion         String
  estado_civil      EstadoCivil
  equipo            Equipo
  created_at        DateTime    @default(now()) @db.Timestamp(3)

  ventas            Venta[]

  @@map("clientes")
}

model Venta {
  id                    Int             @id @default(autoincrement())
  id_cliente            Int
  id_asesor             Int
  lote                  String
  mz                    String
  etapa                 Int
  escala                Int?
  area                  Decimal         @db.Decimal(10, 2)
  precio_lista          Decimal         @db.Decimal(12, 2)
  descuento             Decimal         @db.Decimal(12, 2)
  precio_final_dolares  Decimal         @db.Decimal(12, 2)
  precio_final_soles    Decimal         @db.Decimal(12, 2)
  tipo_cambio           Decimal         @db.Decimal(6, 3)
  tipo_moneda           Moneda
  modalidad             Modalidad
  porcentaje_inicial    Decimal         @db.Decimal(6, 2)
  numero_cuotas         Int?
  monto_total_abonado   Decimal         @db.Decimal(12, 2)
  medio_pago            MedioPago
  banco_emisor          String
  numero_operacion      String
  tipo_comprobante      TipoComprobante
  fecha_firma_contrato  DateTime?       @db.Timestamp(3)
  fecha_final_pago      DateTime?       @db.Timestamp(3)
  mes_ultimo_deposito   DateTime        @db.Timestamp(3)
  monto_comision        Decimal?        @db.Decimal(12, 2)
  porcentaje_comision   Decimal?        @db.Decimal(5, 2)
  ventas_por_asesor     Int?
  url_archivo           String?
  observaciones         String?
  marca_temporal        DateTime        @default(now()) @db.Timestamp(3)
  created_at            DateTime        @default(now()) @db.Timestamp(3)

  cliente               Cliente         @relation(fields: [id_cliente], references: [id])
  asesor                Asesor          @relation(fields: [id_asesor], references: [id])

  @@map("ventas")
}