<div class="min-h-screen bg-slate-50 py-8 px-4 sm:px-6 lg:px-8 font-sans">
    
    <div class="max-w-4xl mx-auto mb-4 flex gap-4 text-sm">
        <a href="/" class="text-slate-500 hover:text-slate-800 transition-colors flex items-center">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Ir a Ventas
        </a>
        <span class="text-slate-300">|</span>
        <a href="/clientes" class="text-slate-500 hover:text-slate-800 transition-colors">
            Directorio de Clientes
        </a>
    </div>

    <div class="max-w-4xl mx-auto bg-white rounded-xl shadow-lg overflow-hidden border border-slate-200">
        
        <div class="bg-slate-800 px-6 py-5 sm:px-8">
            <h1 class="text-xl sm:text-2xl font-semibold text-white tracking-wide">
                Editar Cliente <span class="text-blue-400">#<%= cliente.id %></span>
            </h1>
            <p class="text-slate-300 text-sm mt-1">Actualice la información personal, de contacto y el equipo asignado.</p>
        </div>

        <form action="/clientes/<%= cliente.id %>/edit" method="POST" class="p-6 sm:p-8">
            
            <div class="mb-8 bg-slate-50 border border-slate-100 rounded-lg p-6">
                <h2 class="text-lg font-medium text-slate-800 border-b border-slate-200 pb-2 mb-5">
                    1. Información Personal y Laboral
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Equipo Asignado</label>
                        <select name="equipo" class="block w-full px-4 py-2.5 bg-white border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-slate-500 sm:text-sm text-slate-800 font-medium">
                            <option value="VENTAS" <%= cliente.equipo === 'VENTAS' ? 'selected' : '' %>>Ventas</option>
                            <option value="COBRANZA" <%= cliente.equipo === 'COBRANZA' ? 'selected' : '' %>>Cobranza</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Nombre Completo</label>
                        <input type="text" name="nombre_completo" value="<%= cliente.nombre_completo %>" required class="block w-full px-4 py-2.5 bg-white border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-slate-500 sm:text-sm text-slate-800">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">DNI o RUC</label>
                        <input type="text" name="dni_ruc" value="<%= cliente.dni_ruc %>" required class="block w-full px-4 py-2.5 bg-white border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-slate-500 sm:text-sm text-slate-800">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Estado Civil</label>
                        <select name="estado_civil" class="block w-full px-4 py-2.5 bg-white border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-slate-500 sm:text-sm text-slate-800">
                            <option value="SOLTERO" <%= cliente.estado_civil === 'SOLTERO' ? 'selected' : '' %>>Soltero</option>
                            <option value="CASADO" <%= cliente.estado_civil === 'CASADO' ? 'selected' : '' %>>Casado</option>
                            <option value="DIVORCIADO" <%= cliente.estado_civil === 'DIVORCIADO' ? 'selected' : '' %>>Divorciado</option>
                            <option value="VIUDO" <%= cliente.estado_civil === 'VIUDO' ? 'selected' : '' %>>Viudo</option>
                        </select>
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Ocupación</label>
                        <input type="text" name="ocupacion" value="<%= cliente.ocupacion %>" required class="block w-full px-4 py-2.5 bg-white border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-slate-500 sm:text-sm text-slate-800">
                    </div>
                </div>
            </div>

            <div class="mb-8">
                <h2 class="text-lg font-medium text-slate-800 border-b border-slate-200 pb-2 mb-5">
                    2. Contacto y Residencia
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Celular</label>
                        <input type="text" name="celular" value="<%= cliente.celular %>" required class="block w-full px-4 py-2.5 bg-white border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-slate-500 sm:text-sm text-slate-800">
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Dirección</label>
                        <input type="text" name="direccion" value="<%= cliente.direccion %>" required class="block w-full px-4 py-2.5 bg-white border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-slate-500 sm:text-sm text-slate-800">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Departamento</label>
                        <input type="text" name="departamento" value="<%= cliente.departamento %>" required class="block w-full px-4 py-2.5 bg-white border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-slate-500 sm:text-sm text-slate-800">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Provincia</label>
                        <input type="text" name="provincia" value="<%= cliente.provincia %>" required class="block w-full px-4 py-2.5 bg-white border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-slate-500 sm:text-sm text-slate-800">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Distrito</label>
                        <input type="text" name="distrito" value="<%= cliente.distrito %>" required class="block w-full px-4 py-2.5 bg-white border border-slate-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-slate-500 sm:text-sm text-slate-800">
                    </div>
                </div>
            </div>

            <div class="pt-6 border-t border-slate-200 flex flex-col-reverse sm:flex-row justify-end items-center gap-4">
                <a href="/clientes" class="w-full sm:w-auto px-6 py-2.5 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-md shadow-sm hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-500 transition-colors text-center">
                    Cancelar
                </a>
                <button type="submit" class="w-full sm:w-auto px-8 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-md shadow-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-600 transition-all duration-200 ease-in-out transform hover:-translate-y-0.5">
                    Actualizar Cliente
                </button>
            </div>
            
        </form>
    </div>
</div>
<%- include('../partials/footer') %>