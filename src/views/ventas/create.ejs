<script>
    function toggleClienteForm() {
            const tipo = document.querySelector('input[name="tipo_cliente"]:checked').value;
            const divExistente = document.getElementById('div-cliente-existente');
            const divNuevo = document.getElementById('div-cliente-nuevo');
            const selectExistente = document.getElementById('cliente_id');

            if (tipo === 'existente') {
                divExistente.classList.remove('hidden');
                divNuevo.classList.add('hidden');
                selectExistente.required = true;
            } else {
                divExistente.classList.add('hidden');
                divNuevo.classList.remove('hidden');
                selectExistente.required = false;
                selectExistente.value = "";
            }
        }

    toggleClienteForm();
    
    function toggleClienteForm() {
        const tipo = document.querySelector('input[name="tipo_cliente"]:checked').value;
        const divExistente = document.getElementById('div-cliente-existente');
        const divNuevo = document.getElementById('div-cliente-nuevo');

        if (tipo === 'existente') {
            divExistente.classList.remove('hidden');
            divNuevo.classList.add('hidden');
        } else {
            divExistente.classList.add('hidden');
            divNuevo.classList.remove('hidden');
        }
    }
    
    document.addEventListener('DOMContentLoaded', toggleClienteForm);
</script>
