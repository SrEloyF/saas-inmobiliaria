<div class="min-h-screen bg-slate-50 py-8 px-4 sm:px-6 lg:px-8 font-sans">
    
    <div class="max-w-7xl mx-auto">
        
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
            <div>
                <h1 class="text-2xl sm:text-3xl font-bold text-slate-800 tracking-tight">Registro de Ventas</h1>
                <p class="text-sm text-slate-500 mt-1">Gestión general de ventas y asignación de lotes del proyecto.</p>
            </div>
            
            <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
                <a href="/clientes" class="inline-flex justify-center items-center px-4 py-2.5 bg-white border border-slate-300 rounded-md shadow-sm text-sm font-medium text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-500 transition-all">
                    <svg class="w-5 h-5 mr-2 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                    Directorio de Clientes
                </a>
                
                <a href="/create" class="inline-flex justify-center items-center px-4 py-2.5 bg-slate-800 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-800 transition-all transform hover:-translate-y-0.5">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                    Registrar Nueva Venta
                </a>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-md border border-slate-200 overflow-hidden">
            
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-800">
                        <tr>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-100 uppercase tracking-wider">ID</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-100 uppercase tracking-wider">Cliente</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-100 uppercase tracking-wider">Asesor</th>
                            <th scope="col" class="px-6 py-4 text-center text-xs font-semibold text-slate-100 uppercase tracking-wider">Ubicación</th>
                            <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-100 uppercase tracking-wider">Área</th>
                            <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-100 uppercase tracking-wider">Monto Final</th>
                            <th scope="col" class="px-6 py-4 text-center text-xs font-semibold text-slate-100 uppercase tracking-wider">Moneda</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-100 uppercase tracking-wider">Registro</th>
                            <th scope="col" class="px-6 py-4 text-center text-xs font-semibold text-slate-100 uppercase tracking-wider">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-100">
                        
                        <% if (ventas.length === 0) { %>
                            <tr>
                                <td colspan="9" class="px-6 py-16 text-center text-slate-500 bg-slate-50/50">
                                    <svg class="mx-auto h-12 w-12 text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                    </svg>
                                    <p class="text-base font-medium text-slate-800">No hay ventas registradas</p>
                                    <p class="text-sm mt-1">Aún no se ha generado ningún movimiento comercial en el sistema.</p>
                                </td>
                            </tr>
                        <% } %>

                        <% ventas.forEach(venta => { %>
                            <tr class="hover:bg-slate-50 transition-colors duration-150">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-slate-600">
                                    #<%= venta.id %>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <a href="/clientes/<%= venta.cliente.id %>/edit" class="text-blue-600 hover:text-blue-800 hover:underline">
                                        <%= venta.cliente?.nombre_completo || 'Sin asignar' %>
                                    </a>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600">
                                    <%= venta.asesor?.nombre_completo || 'Sin asignar' %>
                                </td>
                                
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-700 font-medium text-center">
                                    Mz <span class="text-slate-900"><%= venta.mz %></span> - Lt <span class="text-slate-900"><%= venta.lote %></span>
                                </td>
                                
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 text-right">
                                    <%= venta.area %> m²
                                </td>
                                
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900 font-semibold text-right">
                                    <% if (venta.tipo_moneda === 'Dolares') { %>
                                        $<%= venta.precio_final_dolares %>
                                    <% } else { %>
                                        S/ <%= venta.precio_final_soles %>
                                    <% } %>
                                </td>
                                
                                <td class="px-6 py-4 whitespace-nowrap text-center text-sm">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= venta.tipo_moneda === 'Dolares' ? 'bg-emerald-100 text-emerald-800 border border-emerald-200' : 'bg-blue-100 text-blue-800 border border-blue-200' %>">
                                        <%= venta.tipo_moneda %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                    <%= venta.created_at ? new Date(venta.created_at).toLocaleDateString() : '-' %>
                                </td>
                                
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-center">
                                    <div class="flex items-center justify-center space-x-4">
                                        <a href="/<%= venta.id %>/edit" class="text-slate-400 hover:text-blue-600 transition-colors" title="Editar Venta">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                            </svg>
                                        </a>
                                        
                                        <form action="/<%= venta.id %>/delete" method="POST" class="inline-block m-0" onsubmit="return confirm('¿Seguro que deseas eliminar el registro de esta venta? Esta acción es irreversible.');">
                                            <button type="submit" class="text-slate-400 hover:text-red-600 transition-colors cursor-pointer" title="Eliminar Venta">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                                </svg>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>

                    </tbody>
                </table>
            </div>

            <% if (ventas.length > 0) { %>
            <div class="bg-slate-50 px-6 py-4 border-t border-slate-200">
                <p class="text-sm text-slate-500">
                    Mostrando un total de <span class="font-medium text-slate-900"><%= ventas.length %></span> registros en el sistema.
                </p>
            </div>
            <% } %>

        </div>
    </div>
</div>
<%- include('../partials/footer') %>