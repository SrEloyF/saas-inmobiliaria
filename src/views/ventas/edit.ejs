                    Cancelar
                </a>
                <button type="submit" class="w-full sm:w-auto px-8 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-md shadow-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-600 transition-all duration-200 ease-in-out transform hover:-translate-y-0.5">
                    Actualizar Venta
                </button>
            </div>
            
        </form>
    </div>
</div>

<script>
    function actualizarPorcentaje() {
        const totalAbonado = parseFloat(document.querySelector('[name="monto_total_abonado"]').value) || 0;
        const precioFinal = parseFloat(document.querySelector('[name="precio_final_dolares"]').value) || 0;

        const porcentajeInput = document.getElementById('porcentaje_inicial');

        if (precioFinal > 0) {
            const porcentaje = (totalAbonado / precioFinal) * 100;
            porcentajeInput.value = porcentaje.toFixed(2);
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        const abonado = document.querySelector('[name="monto_total_abonado"]');
        const precio = document.querySelector('[name="precio_final_dolares"]');
        const porcentajeInput = document.getElementById('porcentaje_inicial');

        if (!porcentajeInput.value) {
            abonado.addEventListener("input", actualizarPorcentaje);
            precio.addEventListener("input", actualizarPorcentaje);
            actualizarPorcentaje();
        }
    });
</script>

<%- include('../partials/footer') %>